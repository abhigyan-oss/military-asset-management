generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  BASE_COMMANDER
  LOGISTICS_OFFICER
}

enum EquipmentType {
  WEAPON
  VEHICLE
  AMMUNITION
  COMMUNICATION
  MEDICAL
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Base {
  id        String   @id @default(cuid())
  name      String
  location  String

  createdAt DateTime @default(now())
}